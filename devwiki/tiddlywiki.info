{
  "description": "TW-Chart development wiki",
  "plugins": [
    "tiddlywiki/filesystem",
    "tiddlywiki/tiddlyweb",
    "nikorion/chart"
  ],
  "themes": [
    "tiddlywiki/vanilla"
  ],
  "pluginPath": "../plugins",
  "build": {
    "plugin-json": [
      "--output", "dist",
      "--savetiddler", "$:/plugins/nikorion/chart", "TW-Chart-Plugin.json", "application/json"
    ],
    "html": [
      "--output", "docs",
      "--rendertiddler", "$:/core/save/all", "TW-Chart-Wiki.html", "text/plain"
    ]
  }
}
